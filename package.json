{
    "name":  "bench-vscode",
    "displayName":  "Bench",
    "description":  "A Copilot-style feature planning chat with measured-option cards for VS Code.",
    "version":  "0.0.1",
    "publisher":  "bench",
    "engines":  {
                    "vscode":  "^1.92.0"
                },
    "categories":  [
                       "Other"
                   ],
    "activationEvents":  [
                             "onView:bench.chatView",
                             "onCommand:bench.openChat",
                             "onCommand:bench.newFeatureChat"
                         ],
    "main":  "./dist/extension.js",
    "contributes":  {
                        "configuration":  {
                                              "title":  "Bench",
                                              "properties":  {
                                                                 "bench.orchestratorUrl":  {
                                                                                               "type":  "string",
                                                                                               "default":  "http://127.0.0.1:8000",
                                                                                               "description":  "Local Bench orchestrator URL used by the VS Code extension."
                                                                                           }
                                                             }
                                          },
                        "commands":  [
                                         {
                                             "command":  "bench.openChat",
                                             "title":  "Bench: Open Chat"
                                         },
                                         {
                                             "command":  "bench.newFeatureChat",
                                             "title":  "Bench: Start New Feature Chat"
                                         }
                                     ],
                        "viewsContainers":  {
                                                "activitybar":  [
                                                                    {
                                                                        "id":  "bench",
                                                                        "title":  "Bench",
                                                                        "icon":  "media/bench.svg"
                                                                    }
                                                                ]
                                            },
                        "views":  {
                                      "bench":  [
                                                    {
                                                        "id":  "bench.chatView",
                                                        "name":  "Chat",
                                                        "type":  "webview"
                                                    }
                                                ]
                                  },
                        "menus":  {
                                      "commandPalette":  [
                                                             {
                                                                 "command":  "bench.openChat"
                                                             },
                                                             {
                                                                 "command":  "bench.newFeatureChat"
                                                             }
                                                         ]
                                  }
                    },
    "scripts":  {
                    "compile":  "tsc -p ./",
                    "watch":  "tsc -watch -p ./",
                    "lint":  "tsc --noEmit -p ./",
                    "vscode:prepublish":  "npm run compile"
                },
    "devDependencies":  {
                            "@types/node":  "^20.14.10",
                            "@types/vscode":  "^1.92.0",
                            "typescript":  "^5.5.3"
                        }
}
