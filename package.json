{
  "name": "bench-vscode",
  "displayName": "Bench",
  "description": "A Copilot-style feature planning chat with measured-option cards for VS Code.",
  "version": "0.0.1",
  "publisher": "bench",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:bench.chatView",
    "onCommand:bench.openChat",
    "onCommand:bench.newFeatureChat",
    "onCommand:bench.setCerebrasApiKey"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Bench",
      "properties": {
        "bench.cerebrasModel": {
          "type": "string",
          "default": "llama-4-scout-17b-16e-instruct",
          "description": "Cerebras model used to generate Bench implementation suggestions."
        },
        "bench.cerebrasApiKey": {
          "type": "string",
          "default": "",
          "description": "Optional Cerebras API key fallback. Prefer the Bench: Set Cerebras API Key command, which stores the key in VS Code SecretStorage."
        }
      }
    },
    "commands": [
      {
        "command": "bench.openChat",
        "title": "Bench: Open Chat"
      },
      {
        "command": "bench.newFeatureChat",
        "title": "Bench: Start New Feature Chat"
      },
      {
        "command": "bench.setCerebrasApiKey",
        "title": "Bench: Set Cerebras API Key"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bench",
          "title": "Bench",
          "icon": "media/bench.svg"
        }
      ]
    },
    "views": {
      "bench": [
        {
          "id": "bench.chatView",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "bench.openChat"
        },
        {
          "command": "bench.newFeatureChat"
        },
        {
          "command": "bench.setCerebrasApiKey"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc --noEmit -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.92.0",
    "typescript": "^5.5.3"
  }
}
